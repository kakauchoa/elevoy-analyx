generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum TipoUsuario {
  gestor
  cliente
}

enum TipoFunil {
  whatsapp
  landing_page_lead
  landing_page_contato
  ecommerce
  conteudo
  ecommerce_conteudo
  outro
}

enum StatusCampanha {
  ACTIVE
  PAUSED
  ARCHIVED
  DELETED
}

enum NivelInsight {
  conta
  campanha
  conjunto
  anuncio
}

enum TipoDispositivo {
  desktop
  mobile
  tablet
  desconhecido
}

enum TipoPagamento {
  cartao
  boleto
}

enum StatusLeadWpp {
  ENTROU
  QUALIFICADO
  PAGAMENTO
  VENDA
}

enum StatusClienteCrm {
  pendente
  aprovado
  rejeitado
}

enum TokenStatus {
  ok
  expirando
  expirado
  erro
}

enum PerfilUsuario {
  admin
  gestor
  comercial
}

enum PlanoUsuario {
  free
  basico
  intermediario
  personalizado
}

enum DesempenhoCampanhas {
  otimo
  bom
  regular
  ruim
  pessimo
}

enum StatusPagamentoCliente {
  pago
  pendente
  inadimplente
}

model Usuario {
  id                   String            @id @default(uuid())
  nome                 String
  email                String            @unique
  senhaHash            String            @map("senha_hash") @db.Text
  tipo                 TipoUsuario       @default(gestor)
  perfil               PerfilUsuario     @default(gestor) @map("perfil")
  ativo                Boolean           @default(true)
  stripeCustomerId     String?           @unique @map("stripe_customer_id") @db.VarChar(255)
  stripeSubscriptionId String?           @map("stripe_subscription_id") @db.VarChar(255)
  plano                PlanoUsuario      @default(free)
  contasMaximas        Int               @default(3) @map("contas_maximas")
  assinaturaAtiva      Boolean           @default(false) @map("assinatura_ativa")
  assinaturaVenceEm    DateTime?         @map("assinatura_vence_em")
  criadoEm             DateTime          @default(now()) @map("criado_em")
  atualizadoEm         DateTime          @updatedAt @map("atualizado_em")
  contas              ContaAnuncio[]
  relatorios          RelatorioGerado[]
  gestorContas        GestorConta[]
  configuracaoMetaApp ConfiguracaoMetaApp?
  permissoes          UsuarioPermissao[]
  etapasCrm           CrmEtapa[]
  contatosCrm         CrmContato[]
  tagsCrm             CrmTag[]
  integracaoGoogle    IntegracaoGoogle?
  prospeccoes         ProspeccaoGmn[]
  historicosPesquisa  HistoricoPesquisaGmn[]
  clientesAgencia     ClienteAgencia[]

  @@map("usuarios")
}

model ContaAnuncio {
  id                     String            @id @default(uuid())
  usuarioId              String            @map("usuario_id")
  nomeCliente            String            @map("nome_cliente")
  slugCompartilhavel     String            @unique @map("slug_compartilhavel")
  accountIdMeta          String            @map("account_id_meta")
  tokenAcesso            String?           @db.Text @map("token_acesso")
  pageIdMeta             String?           @db.VarChar(100) @map("page_id_meta")
  webhookToken           String?           @unique @db.VarChar(100) @map("webhook_token")
  evolutionInstanceName  String?           @db.VarChar(100) @map("evolution_instance_name")
  evolutionStatus        String?           @db.VarChar(30) @map("evolution_status")
  dataEntrada            DateTime?         @db.Date @map("data_entrada")
  tipoFunil              TipoFunil         @map("tipo_funil")
  metricaPrincipal       String            @map("metrica_principal")
  labelMetricaPrincipal  String            @map("label_metrica_principal")
  labelCustoPorResultado String            @map("label_custo_por_resultado")
  compartilhamentoAtivo  Boolean           @default(false) @map("compartilhamento_ativo")
  ultimaSincronizacao    DateTime?         @map("ultima_sincronizacao")
  tokenExpiraEm          DateTime?         @map("token_expira_em")
  tokenStatus            TokenStatus       @default(ok) @map("token_status")
  tipoPagamento          TipoPagamento     @default(cartao) @map("tipo_pagamento")
  orcamentoMensal        Decimal?          @db.Decimal(10, 2) @map("orcamento_mensal")
  saldoAtual             Decimal?          @db.Decimal(15, 2) @map("saldo_atual")
  saldoAtualizadoEm      DateTime?         @map("saldo_atualizado_em")
  limiteAlertaSaldo      Decimal?          @db.Decimal(10, 2) @map("limite_alerta_saldo")
  rastreamentoAtivo      Boolean           @default(true) @map("rastreamento_ativo")
  rastreamentoApenas     Boolean           @default(false) @map("rastreamento_apenas")
  clienteAgenciaId       String?           @map("cliente_agencia_id")
  ativo                  Boolean           @default(true)
  criadoEm               DateTime          @default(now()) @map("criado_em")
  atualizadoEm           DateTime          @updatedAt @map("atualizado_em")
  usuario                Usuario           @relation(fields: [usuarioId], references: [id])
  clienteAgencia         ClienteAgencia?   @relation(fields: [clienteAgenciaId], references: [id])
  campanhas              Campanha[]
  insights               InsightDiario[]
  acessos                AcessoDashboard[]
  relatorios             RelatorioGerado[]
  configuracaoGtm        ConfiguracaoGtm?
  configuracaoDashboard  ConfiguracaoDashboard?
  gestorContas           GestorConta[]
  notificacoes           NotificacaoSaldo[]
  leadsWpp               LeadWpp[]
  clientesCrm            ClienteCrm[]

  @@map("contas_anuncio")
}

model GestorConta {
  id             String       @id @default(uuid())
  usuarioId      String       @map("usuario_id")
  contaAnuncioId String       @map("conta_anuncio_id")
  criadoEm       DateTime     @default(now()) @map("criado_em")
  usuario        Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  conta          ContaAnuncio @relation(fields: [contaAnuncioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, contaAnuncioId])
  @@map("gestor_contas")
}

model Campanha {
  id             String            @id @default(uuid())
  contaAnuncioId String            @map("conta_anuncio_id")
  campanhaIdMeta String            @unique @map("campanha_id_meta")
  nome           String            @db.VarChar(500)
  status         StatusCampanha
  objetivo       String?
  criadoEm       DateTime          @default(now()) @map("criado_em")
  atualizadoEm   DateTime          @updatedAt @map("atualizado_em")
  conta          ContaAnuncio      @relation(fields: [contaAnuncioId], references: [id])
  conjuntos      ConjuntoAnuncio[]

  @@map("campanhas")
}

model ConjuntoAnuncio {
  id           String         @id @default(uuid())
  campanhaId   String         @map("campanha_id")
  adsetIdMeta  String         @unique @map("adset_id_meta")
  nome         String         @db.VarChar(500)
  status       StatusCampanha
  criadoEm     DateTime       @default(now()) @map("criado_em")
  atualizadoEm DateTime       @updatedAt @map("atualizado_em")
  campanha     Campanha       @relation(fields: [campanhaId], references: [id])
  anuncios     Anuncio[]

  @@map("conjuntos_anuncio")
}

model Anuncio {
  id            String          @id @default(uuid())
  conjuntoId    String          @map("conjunto_anuncio_id")
  anuncioIdMeta String          @unique @map("anuncio_id_meta")
  nome          String          @db.VarChar(500)
  status        StatusCampanha
  criadoEm      DateTime        @default(now()) @map("criado_em")
  atualizadoEm  DateTime        @updatedAt @map("atualizado_em")
  conjunto      ConjuntoAnuncio @relation(fields: [conjuntoId], references: [id])

  @@map("anuncios")
}

model InsightDiario {
  id                     String       @id @default(uuid())
  contaAnuncioId         String       @map("conta_anuncio_id")
  nivel                  NivelInsight
  referenciaId           String?      @map("referencia_id")
  referenciaMetaId       String       @map("referencia_meta_id")
  data                   DateTime     @db.Date
  spend                  Decimal?     @db.Decimal(15, 4)
  impressions            BigInt?
  reach                  BigInt?
  clicks                 BigInt?
  inlineLinkClicks       BigInt?      @map("inline_link_clicks")
  cpm                    Decimal?     @db.Decimal(10, 4)
  ctr                    Decimal?     @db.Decimal(10, 6)
  cpc                    Decimal?     @db.Decimal(10, 4)
  cpp                    Decimal?     @db.Decimal(10, 4)
  frequency              Decimal?     @db.Decimal(10, 4)
  uniqueClicks           BigInt?      @map("unique_clicks")
  uniqueCtr              Decimal?     @map("unique_ctr") @db.Decimal(10, 6)
  landingPageViews       BigInt?      @map("landing_page_views")
  landingPageViewRate    Decimal?     @map("landing_page_view_rate") @db.Decimal(10, 6)
  outboundClicks         BigInt?      @map("outbound_clicks")
  outboundCtr            Decimal?     @map("outbound_ctr") @db.Decimal(10, 6)
  resultadoPrincipal     BigInt?      @map("resultado_principal")
  tipoResultadoPrincipal String?      @map("tipo_resultado_principal")
  custoPorResultado      Decimal?     @map("custo_por_resultado") @db.Decimal(10, 4)
  whatsappClicks         BigInt?      @map("whatsapp_clicks")
  whatsappCost           Decimal?     @map("whatsapp_cost") @db.Decimal(10, 4)
  leadCount              BigInt?      @map("lead_count")
  costPerLead            Decimal?     @map("cost_per_lead") @db.Decimal(10, 4)
  purchaseCount          BigInt?      @map("purchase_count")
  purchaseValue          Decimal?     @map("purchase_value") @db.Decimal(15, 4)
  purchaseRoas           Decimal?     @map("purchase_roas") @db.Decimal(10, 4)
  costPerPurchase        Decimal?     @map("cost_per_purchase") @db.Decimal(10, 4)
  addToCart              BigInt?      @map("add_to_cart")
  initiateCheckout       BigInt?      @map("initiate_checkout")
  contactCount           BigInt?      @map("contact_count")
  costPerContact         Decimal?     @map("cost_per_contact") @db.Decimal(10, 4)
  postEngagement         BigInt?      @map("post_engagement")
  postReactions          BigInt?      @map("post_reactions")
  postComments           BigInt?      @map("post_comments")
  postShares             BigInt?      @map("post_shares")
  pageLikes              BigInt?      @map("page_likes")
  videoView3s            BigInt?      @map("video_view_3s")
  videoView10s           BigInt?      @map("video_view_10s")
  videoView25pct         BigInt?      @map("video_view_25pct")
  videoView50pct         BigInt?      @map("video_view_50pct")
  videoView75pct         BigInt?      @map("video_view_75pct")
  videoView95pct         BigInt?      @map("video_view_95pct")
  videoView100pct        BigInt?      @map("video_view_100pct")
  videoAvgTimeWatched    Decimal?     @map("video_avg_time_watched") @db.Decimal(10, 4)
  videoPlayActions       BigInt?      @map("video_play_actions")
  videoThruplay          BigInt?      @map("video_thruplay")
  costPerThruplay        Decimal?     @map("cost_per_thruplay") @db.Decimal(10, 4)
  sincronizadoEm         DateTime     @default(now()) @map("sincronizado_em")
  criadoEm               DateTime     @default(now()) @map("criado_em")
  conta                  ContaAnuncio @relation(fields: [contaAnuncioId], references: [id])

  @@unique([contaAnuncioId, nivel, referenciaMetaId, data])
  @@map("insights_diarios")
}

model AcessoDashboard {
  id              String          @id @default(uuid())
  contaAnuncioId  String          @map("conta_anuncio_id")
  slug            String
  nomeVisitante   String?         @map("nome_visitante") @db.VarChar(255)
  ipVisitante     String?         @map("ip_visitante") @db.VarChar(45)
  userAgent       String?         @map("user_agent") @db.Text
  referrer        String?         @db.Text
  pais            String?         @db.VarChar(300)
  dispositivo     TipoDispositivo @default(desconhecido)
  duracaoSegundos Int?            @map("duracao_segundos")
  acessadoEm      DateTime        @default(now()) @map("acessado_em")
  conta           ContaAnuncio    @relation(fields: [contaAnuncioId], references: [id])

  @@map("acessos_dashboard")
}

model RelatorioGerado {
  id             String       @id @default(uuid())
  contaAnuncioId String       @map("conta_anuncio_id")
  geradoPorId    String       @map("gerado_por_id")
  conteudo       String       @db.LongText
  periodoInicio  DateTime     @db.Date @map("periodo_inicio")
  periodoFim     DateTime     @db.Date @map("periodo_fim")
  criadoEm       DateTime     @default(now()) @map("criado_em")
  conta          ContaAnuncio @relation(fields: [contaAnuncioId], references: [id])
  geradoPor      Usuario      @relation(fields: [geradoPorId], references: [id])

  @@map("relatorios_gerados")
}

model ConfiguracaoMetaApp {
  id            String      @id @default(uuid())
  usuarioId     String      @unique @map("usuario_id")
  appId         String      @map("app_id") @db.VarChar(100)
  appSecret     String      @map("app_secret") @db.Text
  tokenAcesso   String?     @db.Text @map("token_acesso")
  tokenExpiraEm DateTime?   @map("token_expira_em")
  tokenStatus   TokenStatus @default(ok) @map("token_status")
  criadoEm      DateTime    @default(now()) @map("criado_em")
  atualizadoEm  DateTime    @updatedAt @map("atualizado_em")
  usuario       Usuario     @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("configuracoes_meta_app")
}

model UsuarioPermissao {
  id        String  @id @default(uuid())
  usuarioId String  @map("usuario_id")
  secao     String  @db.VarChar(50)
  usuario   Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, secao])
  @@map("usuario_permissoes")
}

model CrmEtapa {
  id        String       @id @default(uuid())
  usuarioId String       @map("usuario_id")
  nome      String       @db.VarChar(100)
  cor       String       @db.VarChar(20)
  ordem     Int
  fixo      Boolean      @default(false)
  criadoEm  DateTime     @default(now()) @map("criado_em")
  usuario   Usuario      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  contatos  CrmContato[]

  @@map("crm_etapas")
}

model CrmContato {
  id                    String               @id @default(uuid())
  etapaId               String               @map("etapa_id")
  usuarioId             String               @map("usuario_id")
  nome                  String               @db.VarChar(255)
  telefone              String?              @db.VarChar(30)
  empresa               String?              @db.VarChar(255)
  email                 String?              @db.VarChar(255)
  notas                 String?              @db.Text
  dataContato           DateTime?            @map("data_follow_up")
  dataMensagem          DateTime?            @map("data_mensagem")
  dataReuniao           DateTime?            @map("data_reuniao")
  googleCalendarEventId String?              @map("google_calendar_event_id") @db.VarChar(255)
  criadoEm              DateTime             @default(now()) @map("criado_em")
  atualizadoEm          DateTime             @updatedAt @map("atualizado_em")
  etapa                 CrmEtapa             @relation(fields: [etapaId], references: [id], onDelete: Cascade)
  usuario               Usuario              @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  campos                CrmCampoCustomizado[]
  tags                  CrmContatoTag[]

  @@map("crm_contatos")
}

model CrmCampoCustomizado {
  id        String     @id @default(uuid())
  contatoId String     @map("contato_id")
  chave     String     @db.VarChar(100)
  valor     String     @db.Text
  contato   CrmContato @relation(fields: [contatoId], references: [id], onDelete: Cascade)

  @@map("crm_campos_customizados")
}

model CrmTag {
  id        String          @id @default(uuid())
  usuarioId String          @map("usuario_id")
  nome      String          @db.VarChar(50)
  cor       String          @db.VarChar(20)
  criadoEm  DateTime        @default(now()) @map("criado_em")
  usuario   Usuario         @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  contatos  CrmContatoTag[]

  @@map("crm_tags")
}

model CrmContatoTag {
  id        String     @id @default(uuid())
  contatoId String     @map("contato_id")
  tagId     String     @map("tag_id")
  contato   CrmContato @relation(fields: [contatoId], references: [id], onDelete: Cascade)
  tag       CrmTag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([contatoId, tagId])
  @@map("crm_contato_tags")
}

model IntegracaoGoogle {
  id           String   @id @default(uuid())
  usuarioId    String   @unique @map("usuario_id")
  accessToken  String   @db.Text @map("access_token")
  refreshToken String   @db.Text @map("refresh_token")
  expiresAt    DateTime @map("expires_at")
  criadoEm     DateTime @default(now()) @map("criado_em")
  atualizadoEm DateTime @updatedAt @map("atualizado_em")
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("integracoes_google")
}

model ProspeccaoGmn {
  id            String   @id @default(uuid())
  usuarioId     String   @map("usuario_id")
  placeId       String   @map("place_id") @db.VarChar(255)
  cidade        String   @db.VarChar(255)
  nicho         String   @db.VarChar(255)
  nome          String   @db.VarChar(500)
  telefone      String?  @db.VarChar(50)
  site          String?  @db.VarChar(500)
  endereco      String?  @db.Text
  avaliacao     Decimal? @db.Decimal(3, 1)
  qtdAvaliacoes Int?     @map("qtd_avaliacoes")
  extraidoEm    DateTime @default(now()) @map("extraido_em")
  enviadoCrm    Boolean  @default(false) @map("enviado_crm")
  crmContatoId  String?  @map("crm_contato_id") @db.VarChar(191)
  usuario       Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, placeId])
  @@map("prospeccoes_gmn")
}

model HistoricoPesquisaGmn {
  id           String   @id @default(uuid())
  usuarioId    String   @map("usuario_id")
  cidade       String   @db.VarChar(255)
  nicho        String   @db.VarChar(255)
  pesquisadoEm DateTime @default(now()) @map("pesquisado_em")
  usuario      Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("historico_pesquisa_gmn")
}

model ConfiguracaoPlataforma {
  id                 String   @id @default(uuid())
  googlePlacesApiKey String?  @map("google_places_api_key") @db.VarChar(500)
  evolutionApiUrl    String?  @map("evolution_api_url") @db.VarChar(500)
  evolutionApiKey    String?  @map("evolution_api_key") @db.VarChar(500)
  evolutionInstance  String?  @map("evolution_instance") @db.VarChar(255)
  evolutionWhatsapp  String?  @map("evolution_whatsapp") @db.VarChar(50)
  evolutionVersion   String?  @map("evolution_version") @db.VarChar(30)
  atualizadoEm      DateTime @updatedAt @map("atualizado_em")

  @@map("configuracoes_plataforma")
}

model NotificacaoSaldo {
  id             String       @id @default(uuid())
  contaAnuncioId String       @map("conta_anuncio_id")
  tipo           String       @db.VarChar(50)
  mensagem       String       @db.Text
  detalhes       Json?
  lida           Boolean      @default(false)
  criadoEm      DateTime     @default(now()) @map("criado_em")
  conta          ContaAnuncio @relation(fields: [contaAnuncioId], references: [id])

  @@map("notificacoes_saldo")
}

model ConfiguracaoDashboard {
  id             String       @id @default(uuid())
  contaAnuncioId String       @unique @map("conta_anuncio_id")
  layout         Json
  atualizadoEm   DateTime     @updatedAt @map("atualizado_em")
  conta          ContaAnuncio @relation(fields: [contaAnuncioId], references: [id])

  @@map("configuracoes_dashboard")
}

model ConfiguracaoGtm {
  id                  String       @id @default(uuid())
  contaAnuncioId      String       @unique @map("conta_anuncio_id")
  gtmContainerId      String?      @map("gtm_container_id") @db.VarChar(50)
  metaPixelId         String?      @map("meta_pixel_id") @db.VarChar(50)
  eventosCustomizados Json?        @map("eventos_customizados")
  ativo               Boolean      @default(false)
  atualizadoEm        DateTime     @updatedAt @map("atualizado_em")
  conta               ContaAnuncio @relation(fields: [contaAnuncioId], references: [id])

  @@map("configuracoes_gtm")
}

model LeadWpp {
  id             String          @id @default(uuid())
  contaAnuncioId String          @map("conta_anuncio_id")
  nome           String          @db.VarChar(255)
  telefone       String          @db.VarChar(30)
  mensagem       String?         @db.Text
  ctwa           String?         @db.VarChar(500)
  sourceId       String?         @db.VarChar(100) @map("source_id")
  campanha       String?         @db.VarChar(500)
  publico        String?         @db.VarChar(500)
  anuncio        String?         @db.VarChar(500)
  origem         String?         @db.VarChar(100)
  midia          String?         @db.VarChar(100)
  status         StatusLeadWpp   @default(ENTROU)
  valor          Decimal?        @db.Decimal(10, 2)
  observacoes    String?         @db.Text
  criadoEm      DateTime        @default(now()) @map("criado_em")
  atualizadoEm  DateTime        @updatedAt @map("atualizado_em")
  conta          ContaAnuncio    @relation(fields: [contaAnuncioId], references: [id])
  historico      LeadWppHistorico[]

  @@index([contaAnuncioId, telefone])
  @@map("leads_wpp")
}

model LeadWppHistorico {
  id           String         @id @default(uuid())
  leadId       String         @map("lead_id")
  statusAntes  StatusLeadWpp? @map("status_antes")
  statusDepois StatusLeadWpp  @map("status_depois")
  eventoMeta   String?        @db.VarChar(100) @map("evento_meta")
  sucesso      Boolean        @default(true)
  resposta     String?        @db.Text
  criadoEm    DateTime       @default(now()) @map("criado_em")
  lead         LeadWpp        @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@map("leads_wpp_historico")
}

model ClienteCrm {
  id             String           @id @default(uuid())
  contaAnuncioId String?          @map("conta_anuncio_id")
  nome           String           @db.VarChar(255)
  email          String           @unique @db.VarChar(255)
  telefone       String?          @db.VarChar(30)
  senhaHash      String           @db.Text @map("senha_hash")
  status         StatusClienteCrm @default(pendente)
  aprovadoEm    DateTime?        @map("aprovado_em")
  aprovadoPorId  String?          @db.VarChar(36) @map("aprovado_por_id")
  criadoEm      DateTime         @default(now()) @map("criado_em")
  atualizadoEm  DateTime         @updatedAt @map("atualizado_em")
  conta          ContaAnuncio?    @relation(fields: [contaAnuncioId], references: [id])
  solicitacoesReset SolicitacaoResetCrm[]

  @@map("clientes_crm")
}

model SolicitacaoResetCrm {
  id          String           @id @default(uuid())
  clienteId   String           @map("cliente_id")
  status      StatusClienteCrm @default(pendente)
  token       String           @unique @db.VarChar(255)
  expiresAt   DateTime         @map("expires_at")
  aprovadoEm DateTime?        @map("aprovado_em")
  criadoEm   DateTime         @default(now()) @map("criado_em")
  cliente     ClienteCrm       @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("solicitacoes_reset_crm")
}

model ClienteAgencia {
  id                    String                   @id @default(uuid())
  usuarioId             String                   @map("usuario_id")
  nome                  String                   @db.VarChar(255)
  cnpj                  String?                  @db.VarChar(18)
  nomeSocio             String?                  @map("nome_socio") @db.VarChar(255)
  telefone              String?                  @db.VarChar(30)
  email                 String?                  @db.VarChar(255)
  dataEntrada           DateTime?                @db.Date @map("data_entrada")
  indicadoPorId         String?                  @map("indicado_por_id")
  observacoes           String?                  @db.Text
  ativo                 Boolean                  @default(true)
  criadoEm              DateTime                 @default(now()) @map("criado_em")
  atualizadoEm          DateTime                 @updatedAt @map("atualizado_em")
  usuario               Usuario                  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  indicadoPor           ClienteAgencia?          @relation("indicacoes", fields: [indicadoPorId], references: [id])
  indicacoes            ClienteAgencia[]         @relation("indicacoes")
  contas                ContaAnuncio[]
  servicos              ServicoCliente[]
  pagamentos            PagamentoCliente[]
  mapaAvaliacao         MapaAvaliacaoCliente?
  mapaEvolucaoConfig    MapaEvolucaoConfig?
  mapaEvolucaoRegistros MapaEvolucaoRegistro[]

  @@map("clientes_agencia")
}

model ServicoCliente {
  id          String         @id @default(uuid())
  clienteId   String         @map("cliente_id")
  nome        String         @db.VarChar(255)
  valorMensal Decimal        @map("valor_mensal") @db.Decimal(10, 2)
  ativo       Boolean        @default(true)
  criadoEm   DateTime       @default(now()) @map("criado_em")
  cliente     ClienteAgencia @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("servicos_cliente")
}

model PagamentoCliente {
  id             String                 @id @default(uuid())
  clienteId      String                 @map("cliente_id")
  valor          Decimal                @db.Decimal(10, 2)
  dataVencimento DateTime               @db.Date @map("data_vencimento")
  dataPagamento  DateTime?              @db.Date @map("data_pagamento")
  status         StatusPagamentoCliente @default(pendente)
  observacoes    String?                @db.Text
  criadoEm      DateTime               @default(now()) @map("criado_em")
  atualizadoEm  DateTime               @updatedAt @map("atualizado_em")
  cliente        ClienteAgencia         @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("pagamentos_cliente")
}

model MapaAvaliacaoCliente {
  id                  String               @id @default(uuid())
  clienteId           String               @unique @map("cliente_id")
  desempenhoCampanhas DesempenhoCampanhas? @map("desempenho_campanhas")
  relacionamento      DesempenhoCampanhas?
  preenchidoGestorEm  DateTime?            @map("preenchido_gestor_em")
  preenchidoClienteEm DateTime?            @map("preenchido_cliente_em")
  atualizadoEm        DateTime             @updatedAt @map("atualizado_em")
  cliente             ClienteAgencia       @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("mapa_avaliacao_clientes")
}

model MapaEvolucaoConfig {
  id                    String         @id @default(uuid())
  clienteId             String         @unique @map("cliente_id")
  metaFaturamentoMensal Decimal?       @map("meta_faturamento_mensal") @db.Decimal(15, 2)
  faturamentoInicio     Decimal?       @map("faturamento_inicio") @db.Decimal(15, 2)
  vendasInicio          Int?           @map("vendas_inicio")
  dataInicio            DateTime?      @db.Date @map("data_inicio")
  observacoes           String?        @db.Text
  criadoEm             DateTime       @default(now()) @map("criado_em")
  atualizadoEm         DateTime       @updatedAt @map("atualizado_em")
  cliente              ClienteAgencia @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@map("mapa_evolucao_config")
}

model MapaEvolucaoRegistro {
  id            String         @id @default(uuid())
  clienteId     String         @map("cliente_id")
  dataRegistro  DateTime       @db.Date @map("data_registro")
  vendas        Int?
  faturamento   Decimal?       @db.Decimal(15, 2)
  observacoes   String?        @db.Text
  preenchidoPor String         @default("gestor") @map("preenchido_por") @db.VarChar(20)
  criadoEm     DateTime       @default(now()) @map("criado_em")
  cliente       ClienteAgencia @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@unique([clienteId, dataRegistro])
  @@map("mapa_evolucao_registros")
}
